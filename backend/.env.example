ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5000
DATABASE_CONNECTION_STRING=Host=db.example.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=replace-me;SSL Mode=Require;Trust Server Certificate=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
# Only set for legacy HS256 Supabase projects. Leave empty to use issuer JWKS.
SUPABASE_JWT_KEY=
FRONTEND_URL=https://nr-audit-readiness-portal.vercel.app
